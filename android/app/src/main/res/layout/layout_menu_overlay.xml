<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/menu_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <View
        android:id="@+id/menu_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4D000000"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/menu_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_menu_panel"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="14dp"
            android:text="@string/menu_title"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/menu_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/menu_item_profile"
                    layout="@layout/layout_menu_card_row" />

                <include
                    android:id="@+id/menu_item_news"
                    layout="@layout/layout_menu_card_row" />

                <include
                    android:id="@+id/menu_item_offers"
                    layout="@layout/layout_menu_card_row" />

                <include
                    android:id="@+id/menu_item_how_it_works"
                    layout="@layout/layout_menu_card_row" />

                <LinearLayout
                    android:id="@+id/menu_item_server"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/menu_card_height"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_menu_card"
                    android:elevation="2dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <FrameLayout
                        android:layout_width="@dimen/menu_badge_size"
                        android:layout_height="@dimen/menu_badge_size"
                        android:background="@drawable/bg_menu_badge_gray">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_menu_link" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/menu_server"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_menu_chevron"
                        app:tint="@color/text_muted" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menu_server_editor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_menu_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/menu_server_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_login_input"
                        android:hint="@string/login_server_hint"
                        android:inputType="textUri"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/menu_server_save_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/brand_primary"
                        android:text="@string/menu_save"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menu_item_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/menu_card_height"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_menu_card"
                    android:elevation="2dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <FrameLayout
                        android:layout_width="@dimen/menu_badge_size"
                        android:layout_height="@dimen/menu_badge_size"
                        android:background="@drawable/bg_menu_badge_yellow">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_menu_privacy" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/menu_privacy"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_menu_chevron"
                        app:tint="@color/text_muted" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menu_item_terms"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/menu_card_height"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_menu_card"
                    android:elevation="2dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <FrameLayout
                        android:layout_width="@dimen/menu_badge_size"
                        android:layout_height="@dimen/menu_badge_size"
                        android:background="@drawable/bg_menu_badge_gray">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_menu_terms" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/menu_terms"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_menu_chevron"
                        app:tint="@color/text_muted" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menu_item_logout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/menu_card_height"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_menu_card"
                    android:elevation="2dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <FrameLayout
                        android:layout_width="@dimen/menu_badge_size"
                        android:layout_height="@dimen/menu_badge_size"
                        android:background="#1Ae63946">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_menu_logout"
                            app:tint="@color/logout_red" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/menu_logout"
                        android:textColor="@color/logout_red"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_menu_chevron"
                        app:tint="@color/text_muted" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
