<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/onboarding_bg">

    <ImageView
        android:id="@+id/onboarding_scene_bg"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_gravity="bottom"
        android:alpha="0.85"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="88dp"
        android:paddingEnd="28dp"
        android:paddingBottom="180dp">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_onboarding_illus_card"
            android:elevation="4dp"
            android:padding="24dp">

            <ImageView
                android:id="@+id/onboarding_illustration"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:id="@+id/onboarding_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:textColor="@color/brand_black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/onboarding_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingExtra="5dp"
            android:textColor="@color/onboarding_body_text"
            android:textSize="15sp" />
    </LinearLayout>
</FrameLayout>
